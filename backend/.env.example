# ============================================================
# Agency SaaS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.
# ============================================================

# ------ Database ------
# Neon Postgres connection string (pooled URL recommended for serverless)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ------ Redis / Celery ------
# Redis URL from Render (or Upstash)
REDIS_URL=redis://default:password@host:6379

# ------ Clerk Auth ------
# From your Clerk dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...
# JWKS endpoint — https://docs.clerk.com/reference/frontend-api/jwks
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# ------ Encryption ------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ------ CORS ------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ------ LLM (Phase 3) ------
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ------ Email / Resend (Phase 4) ------
RESEND_API_KEY=re_...

# ------ File Storage / Cloudflare R2 ------
# From your Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=agency-saas-logos
# Required: public-facing URL where uploaded files can be fetched.
# Use a custom domain mapped to your R2 bucket, or the R2 dev URL:
# e.g. https://your-bucket.your-account-id.workers.dev
R2_PUBLIC_URL=

# ------ App ------
ENVIRONMENT=development
# LOG_LEVEL=INFO
